# Siqueira Memo example configuration. Copy to .env and adjust.
# Do NOT commit real secrets.

SIQUEIRA_ENV=development

# One-command Docker bootstrap ports (localhost-bound by compose)
SIQUEIRA_PUBLIC_PORT=8787
SIQUEIRA_POSTGRES_PORT=5432
SIQUEIRA_REDIS_PORT=6379

# Service
SIQUEIRA_HOST=127.0.0.1
SIQUEIRA_PORT=8787
SIQUEIRA_API_TOKEN=change-me-local-dev-token
# Optional app-level /admin form login. Keep real values in .env only.
SIQUEIRA_ADMIN_PASSWORD=change-me-admin-password
SIQUEIRA_ADMIN_SESSION_SECRET=change-me-long-random-session-secret
SIQUEIRA_ADMIN_SESSION_TTL_SECONDS=43200
# Use true only when serving /admin over HTTPS; current private tailnet HTTP uses false.
SIQUEIRA_ADMIN_COOKIE_SECURE=false

# Aggressive memory capture
SIQUEIRA_MEMORY_CAPTURE_MODE=aggressive
SIQUEIRA_MEMORY_CAPTURE_TARGET_RATIO=0.8
SIQUEIRA_MEMORY_CAPTURE_SAVE_RAW_TURNS=true
SIQUEIRA_MEMORY_CAPTURE_EXTRACT_STRUCTURED=true

# Database (Docker/production)
POSTGRES_USER=siqueira
POSTGRES_DB=siqueira_memo
POSTGRES_PASSWORD=change-me-postgres-password
SIQUEIRA_DATABASE_URL=postgresql+asyncpg://siqueira:change-me-postgres-password@127.0.0.1:5432/siqueira_memo

# Database (test/dev fallback, no pgvector)
# SIQUEIRA_DATABASE_URL=sqlite+aiosqlite:///./siqueira_memo.db

# Queue
SIQUEIRA_REDIS_URL=redis://127.0.0.1:6379/0
SIQUEIRA_QUEUE_BACKEND=redis

# Embedding provider: openai | local | mock
# Local Docker bootstrap uses mock so no API key is required.
SIQUEIRA_EMBEDDING_PROVIDER=mock
SIQUEIRA_EMBEDDING_MODEL=text-embedding-3-large
SIQUEIRA_EMBEDDING_DIMS=3072
# SIQUEIRA_OPENAI_API_KEY=replace-with-real-key-only-if-using-openai

# Reranker provider: local | cohere | mock
SIQUEIRA_RERANKER_PROVIDER=mock

# Retention
SIQUEIRA_RETENTION_RETRIEVAL_LOGS_DAYS=180
SIQUEIRA_RETENTION_WORKER_LOGS_DAYS=30

# Observability
SIQUEIRA_LOG_LEVEL=INFO
SIQUEIRA_OTEL_ENABLED=false
